CC       = @CC@
CFLAGS   = @CFLAGS@ -std=c17 -D_XOPEN_SOURCE=700 -D_XOPEN_SOURCE_EXTENDED -D_DEFAULT_SOURCE
LDFLAGS  = @LDFLAGS@
LIBS     = @LIBS@
NCURSES_CFLAGS = @NCURSES_CFLAGS@
SQLITE_CFLAGS  = @SQLITE_CFLAGS@
SQLITE_OBJ     = @SQLITE_OBJ@
PREFIX   = @PREFIX@
BINDIR   = @BINDIR@
MANDIR   = @MANDIR@
VERSION  = @VERSION@

PROG     = browse-sqlite3
ALIAS    = bs3
MANPAGE  = browse-sqlite3.1

SRCS     = src/main.c src/browser.c src/db.c src/ui.c src/input.c src/uniwidth.c src/util.c
OBJS     = $(SRCS:.c=.o)

.PHONY: all install uninstall clean distclean dist check

all: $(ALIAS)

$(ALIAS): $(OBJS) $(SQLITE_OBJ)
	$(CC) $(LDFLAGS) -o $@ $^ $(LIBS)

src/%.o: src/%.c
	$(CC) $(CFLAGS) $(NCURSES_CFLAGS) $(SQLITE_CFLAGS) -Isrc -c -o $@ $<

lib/sqlite3.o: lib/sqlite3.c
	$(CC) -O2 -DSQLITE_THREADSAFE=0 -DSQLITE_OMIT_LOAD_EXTENSION -c -o $@ $<

install: $(ALIAS)
	install -d $(DESTDIR)$(BINDIR)
	install -m 755 $(ALIAS) $(DESTDIR)$(BINDIR)/$(PROG)
	ln -sf $(PROG) $(DESTDIR)$(BINDIR)/$(ALIAS)
	install -d $(DESTDIR)$(MANDIR)/man1
	install -m 644 $(MANPAGE) $(DESTDIR)$(MANDIR)/man1/$(MANPAGE)
	ln -sf $(MANPAGE) $(DESTDIR)$(MANDIR)/man1/$(ALIAS).1

uninstall:
	rm -f $(DESTDIR)$(BINDIR)/$(PROG)
	rm -f $(DESTDIR)$(BINDIR)/$(ALIAS)
	rm -f $(DESTDIR)$(MANDIR)/man1/$(MANPAGE)
	rm -f $(DESTDIR)$(MANDIR)/man1/$(ALIAS).1

clean:
	rm -f $(OBJS) $(SQLITE_OBJ) $(ALIAS)

distclean: clean
	rm -f Makefile

check: $(ALIAS)
	@echo "Build check passed."

EXTRA_DIST = \
	$(MANPAGE) _displaywidth.c configure Makefile.in fetch-sqlite.sh \
	README.md COPYING AUTHORS NEWS ChangeLog INSTALL \
	README.distributions .gitignore \
	contrib/browse-sqlite3.py \
	dist/rpm/browse-sqlite3.spec \
	dist/debian/control dist/debian/rules \
	dist/debian/changelog dist/debian/copyright \
	dist/arch/PKGBUILD \
	dist/alpine/APKBUILD \
	dist/freebsd/Makefile dist/freebsd/pkg-descr \
	dist/freebsd/pkg-plist dist/freebsd/distinfo \
	dist/openbsd/Makefile dist/openbsd/pkg/DESCR dist/openbsd/pkg/PLIST \
	dist/netbsd/Makefile dist/netbsd/DESCR \
	dist/netbsd/PLIST dist/netbsd/distinfo \
	dist/gentoo/browse-sqlite3-1.0.ebuild dist/gentoo/metadata.xml \
	dist/nixos/default.nix \
	dist/slackware/browse-sqlite3.SlackBuild \
	dist/slackware/slack-desc dist/slackware/browse-sqlite3.info

dist:
	rm -rf $(PROG)-$(VERSION)
	mkdir -p $(PROG)-$(VERSION)
	for f in $(EXTRA_DIST); do \
		mkdir -p $(PROG)-$(VERSION)/$$(dirname $$f); \
		cp $$f $(PROG)-$(VERSION)/$$f; \
	done
	cp -r src lib $(PROG)-$(VERSION)/
	tar czf $(PROG)-$(VERSION).tar.gz $(PROG)-$(VERSION)
	rm -rf $(PROG)-$(VERSION)
	@echo "Created $(PROG)-$(VERSION).tar.gz"
