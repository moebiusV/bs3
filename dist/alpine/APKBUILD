# Maintainer: MAINTAINER_NAME <MAINTAINER_EMAIL>
pkgname=browse-sqlite3
pkgver=1.0
pkgrel=0
pkgdesc="Interactive terminal browser for SQLite databases"
url="https://github.com/moebiusV/bs3"
arch="x86_64"
license="BSD-2-Clause"
depends="ncurses-libs sqlite-libs"
makedepends="gcc ncurses-dev sqlite-dev pkgconf"
source="$pkgname-$pkgver.tar.gz"

build() {
    ./configure --prefix=/usr --with-system-sqlite
    make
}

check() {
    make check
}

package() {
    make DESTDIR="$pkgdir" install
    install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}

sha512sums=""
