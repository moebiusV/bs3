#!/bin/sh
# configure script for browse-sqlite3
# Hand-written POSIX shell — no autoconf needed.

set -e

VERSION=1.0

# Defaults
prefix=/usr/local
bindir=
mandir=
datarootdir=
cc=
use_system_sqlite=auto
static_ncurses=auto

# Parse arguments
for arg; do
    case "$arg" in
        --prefix=*)           prefix="${arg#--prefix=}" ;;
        --bindir=*)           bindir="${arg#--bindir=}" ;;
        --mandir=*)           mandir="${arg#--mandir=}" ;;
        --datarootdir=*)      datarootdir="${arg#--datarootdir=}" ;;
        --with-system-sqlite) use_system_sqlite=1 ;;
        --without-system-sqlite) use_system_sqlite=0 ;;
        --with-static-ncurses) static_ncurses=yes ;;
        --without-static-ncurses) static_ncurses=no ;;
        --build=*|--host=*|--target=*) ;; # cross-compilation compat
        CC=*)                 cc="${arg#CC=}" ;;
        --help|-h)
            cat <<EOF
Usage: ./configure [OPTIONS]

Options:
  --prefix=DIR              installation prefix [/usr/local]
  --bindir=DIR              user executables [PREFIX/bin]
  --datarootdir=DIR         read-only data root [PREFIX/share]
  --mandir=DIR              man documentation [DATAROOTDIR/man]
  --with-system-sqlite      require system libsqlite3 (error if not found)
  --without-system-sqlite   force use of bundled amalgamation
  --with-static-ncurses     force static linking of ncursesw
  --without-static-ncurses  force dynamic linking of ncursesw

Environment variables:
  CC        C compiler
  CFLAGS    Compiler flags
  LDFLAGS   Linker flags
EOF
            exit 0
            ;;
        *)
            echo "warning: unrecognized option: $arg" >&2
            ;;
    esac
done

# Derive defaults
: "${datarootdir:=${prefix}/share}"
: "${bindir:=${prefix}/bin}"
: "${mandir:=${datarootdir}/man}"

# Find C compiler
if [ -z "$cc" ]; then
    cc="${CC:-}"
fi
if [ -z "$cc" ]; then
    for try_cc in cc gcc clang; do
        if command -v "$try_cc" >/dev/null 2>&1; then
            cc="$try_cc"
            break
        fi
    done
fi
if [ -z "$cc" ]; then
    echo "error: no C compiler found. Set CC or install gcc/clang." >&2
    exit 1
fi
echo "checking for C compiler... $cc"

# Check compiler works
tmpfile=$(mktemp /tmp/bs3-conftest-XXXXXX.c)
cat > "$tmpfile" <<'CEOF'
#include <stdio.h>
int main(void) { return 0; }
CEOF
if ! "$cc" -o /dev/null "$tmpfile" 2>/dev/null; then
    echo "error: $cc cannot compile a simple program" >&2
    rm -f "$tmpfile"
    exit 1
fi
rm -f "$tmpfile"

# Check for ncursesw
echo "checking for ncursesw..."
NCURSES_CFLAGS=""
NCURSES_LIBS=""

if command -v pkg-config >/dev/null 2>&1; then
    if pkg-config --exists ncursesw 2>/dev/null; then
        # Strip _XOPEN_SOURCE from pkg-config flags (we set our own in CFLAGS)
        NCURSES_CFLAGS=$(pkg-config --cflags ncursesw | sed 's/-D_XOPEN_SOURCE=[^ ]*//g; s/-D_XOPEN_SOURCE_EXTENDED//g')
        NCURSES_LIBS=$(pkg-config --libs ncursesw)
        echo "  found via pkg-config: $NCURSES_LIBS"
    fi
fi

if [ -z "$NCURSES_LIBS" ]; then
    tmpfile=$(mktemp /tmp/bs3-conftest-XXXXXX.c)
    cat > "$tmpfile" <<'CEOF'
#include <ncursesw/curses.h>
int main(void) { initscr(); endwin(); return 0; }
CEOF
    if "$cc" -o /dev/null "$tmpfile" -lncursesw 2>/dev/null; then
        NCURSES_LIBS="-lncursesw"
        echo "  found: -lncursesw"
    elif "$cc" -o /dev/null "$tmpfile" -lncurses 2>/dev/null; then
        NCURSES_LIBS="-lncurses"
        echo "  found: -lncurses (warning: may lack wide-char support)"
    else
        echo "error: ncursesw not found. Install libncursesw5-dev or ncurses-devel." >&2
        rm -f "$tmpfile"
        exit 1
    fi
    rm -f "$tmpfile"
fi

# Decide static vs dynamic ncurses
LIBS="$NCURSES_LIBS"
if [ "$static_ncurses" = "yes" ] || [ "$static_ncurses" = "auto" ]; then
    ncurses_static_a=""
    for dir in /usr/lib /usr/lib/x86_64-linux-gnu /usr/lib64 /usr/local/lib; do
        if [ -f "$dir/libncursesw.a" ]; then
            ncurses_static_a="$dir/libncursesw.a"
            break
        fi
    done
    if [ -n "$ncurses_static_a" ]; then
        LIBS="$ncurses_static_a"
        tinfo_a=$(echo "$ncurses_static_a" | sed 's/libncursesw\.a/libtinfo.a/')
        if [ -f "$tinfo_a" ]; then
            LIBS="$LIBS $tinfo_a"
        fi
        echo "  static ncurses: $LIBS"
    elif [ "$static_ncurses" = "yes" ]; then
        echo "error: --with-static-ncurses requested but libncursesw.a not found" >&2
        exit 1
    fi
fi

# SQLite
SQLITE_CFLAGS=""
SQLITE_OBJ=""
found_system_sqlite=0

if [ "$use_system_sqlite" != "0" ]; then
    echo "checking for system sqlite3..."
    if command -v pkg-config >/dev/null 2>&1 && pkg-config --exists sqlite3 2>/dev/null; then
        SQLITE_CFLAGS=$(pkg-config --cflags sqlite3)
        LIBS="$LIBS $(pkg-config --libs sqlite3)"
        echo "  found via pkg-config"
        found_system_sqlite=1
    else
        # Try linking directly
        tmpfile=$(mktemp /tmp/bs3-conftest-XXXXXX.c)
        cat > "$tmpfile" <<'CEOF'
#include <sqlite3.h>
int main(void) { sqlite3 *db; sqlite3_open(":memory:", &db); return 0; }
CEOF
        if "$cc" -o /dev/null "$tmpfile" -lsqlite3 2>/dev/null; then
            LIBS="$LIBS -lsqlite3"
            echo "  found: -lsqlite3"
            found_system_sqlite=1
        fi
        rm -f "$tmpfile"
    fi
    if [ "$found_system_sqlite" = "0" ] && [ "$use_system_sqlite" = "1" ]; then
        echo "error: --with-system-sqlite requested but libsqlite3 not found." >&2
        echo "  Install libsqlite3-dev or sqlite3-devel." >&2
        exit 1
    fi
fi

if [ "$found_system_sqlite" = "0" ]; then
    if [ ! -f lib/sqlite3.c ]; then
        echo "error: neither system libsqlite3 nor bundled amalgamation found." >&2
        echo "  Install libsqlite3-dev, or run: ./fetch-sqlite.sh" >&2
        exit 1
    fi
    echo "using bundled SQLite amalgamation"
    SQLITE_CFLAGS="-Ilib -DSQLITE_THREADSAFE=0 -DSQLITE_OMIT_LOAD_EXTENSION"
    SQLITE_OBJ="lib/sqlite3.o"
fi

# Add pthread and dl
LIBS="$LIBS -lpthread -ldl"

# Honor environment flags, provide defaults
: "${CFLAGS:=-O2 -Wall -Wextra}"

# Generate Makefile
sed \
    -e "s|@CC@|${cc}|g" \
    -e "s|@CFLAGS@|${CFLAGS}|g" \
    -e "s|@LDFLAGS@|${LDFLAGS:-}|g" \
    -e "s|@LIBS@|${LIBS}|g" \
    -e "s|@NCURSES_CFLAGS@|${NCURSES_CFLAGS}|g" \
    -e "s|@SQLITE_CFLAGS@|${SQLITE_CFLAGS}|g" \
    -e "s|@SQLITE_OBJ@|${SQLITE_OBJ}|g" \
    -e "s|@PREFIX@|${prefix}|g" \
    -e "s|@BINDIR@|${bindir}|g" \
    -e "s|@MANDIR@|${mandir}|g" \
    -e "s|@VERSION@|${VERSION}|g" \
    Makefile.in > Makefile

echo ""
echo "browse-sqlite3 $VERSION configured."
echo ""
echo "  prefix:    $prefix"
echo "  bindir:    $bindir"
echo "  mandir:    $mandir"
echo "  compiler:  $cc"
echo "  sqlite:    $([ "$found_system_sqlite" = "1" ] && echo "system" || echo "bundled amalgamation")"
echo "  ncurses:   $LIBS"
echo ""
echo "Run 'make' to build."
